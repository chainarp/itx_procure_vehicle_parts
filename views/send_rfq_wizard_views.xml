<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Send RFQ Wizard Form -->
    <record id="itx_send_rfq_wizard_view_form" model="ir.ui.view">
        <field name="name">itx.send.rfq.wizard.view.form</field>
        <field name="model">itx.send.rfq.wizard</field>
        <field name="arch" type="xml">
            <form string="Send RFQ to Vendors">
                <field name="state" invisible="1"/>

                <!-- Step 1: Select vendors -->
                <group invisible="state != 'draft'">
                    <field name="order_id" readonly="1"/>
                    <field name="vendor_ids" widget="many2many_tags"
                           options="{'no_create': True}"
                           placeholder="Select vendors to send RFQ..."
                           required="state == 'draft'"/>
                    <field name="quote_deadline_minutes"/>
                </group>

                <!-- Step 2: Show portal links with copy button -->
                <div invisible="state != 'done'">
                    <div class="alert alert-success mb-3">
                        <strong>RFQ sent!</strong>
                        Click the copy icon to copy the link, then send to vendor via LINE / phone / email.
                    </div>
                    <field name="created_quote_ids" nolabel="1">
                        <list create="0" delete="0" editable="bottom">
                            <field name="vendor_id" readonly="1"/>
                            <field name="portal_url" widget="CopyClipboardChar"
                                   readonly="1" string="Portal Link"/>
                            <field name="quote_deadline" readonly="1"/>
                        </list>
                    </field>
                </div>

                <footer invisible="state != 'draft'">
                    <button name="action_send_rfq"
                            string="Send RFQ"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
                <footer invisible="state != 'done'">
                    <button string="Close" class="btn-primary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_send_rfq_wizard" model="ir.actions.act_window">
        <field name="name">Send RFQ</field>
        <field name="res_model">itx.send.rfq.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
